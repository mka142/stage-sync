<!DOCTYPE html>
<html>
  <%- include('_semantic_head', { title }) %>

  <body>
    <div class="ui top menu blue" style="height: 42px">
      <div class="ui container">
        <a href="<%= url.admin %>/" class="header item">Panel Admina</a>
      </div>
    </div>
    <div class="ui container" style="margin-top: 2em">
      <div class="ui stackable two column grid">
        <div class="column">
          <div class="">
            <h2 class="ui header">Koncert: <%= concert.name %></h2>
            <div class="ui segment">
              <div class="ui grid">
                <div class="eight wide column">
                  <div class="ui list">
                    <div class="item">
                      <strong>Metadane:</strong>
                      <pre style="display: inline"><%= concert.metadata %></pre>
                    </div>
                    <div class="item">
                      <strong>Status:</strong>
                      <span class="ui <%= concert.isActive ? 'green' : 'grey' %> label"> <%= concert.isActive ? "Aktywny" : "Nieaktywny" %> </span>
                    </div>
                  </div>
                </div>
                <div class="eight wide column" style="text-align: right">
                  <form method="POST" action="<%= url.admin %>/concerts/<%= concert._id %>/<%= concert.isActive ? 'deactivate' : 'activate' %>" style="display: inline">
                    <button type="submit" class="ui <%= concert.isActive ? 'red' : 'green' %> button"><%= concert.isActive ? 'Dezaktywuj' : 'Aktywuj' %> koncert</button>
                  </form>
                </div>
              </div>
            </div>

            <div class="ui clearing segment">
              <h3 class="ui left floated header">Komunikaty</h3>
              <div class="ui right floated buttons">
                <a href="<%= url.admin %>/concerts/<%= concert._id %>/export-events" class="ui basic green button" download>
                  <i class="download icon"></i>Eksportuj wydarzenia
                </a>
                <button class="ui basic blue button" onclick="toggleImportForm()">
                  <i class="upload icon"></i>Importuj wydarzenia
                </button>
                <a href="<%= url.admin %>/events/new/<%= concert._id %>" class="ui basic blue button">
                  <i class="plus icon"></i>Dodaj komunikat
                </a>
              </div>
            </div>

            <!-- Import Events Form (hidden by default) -->
            <div id="import-events-form" class="ui segment" style="display: none; margin-top: 1em;">
              <h4 class="ui header">Importuj wydarzenia z JSON</h4>
              <form method="POST" action="<%= url.admin %>/concerts/<%= concert._id %>/import-events" class="ui form">
                <div class="field">
                  <label>Wklej JSON z wydarzeniami</label>
                  <textarea name="eventsJson" id="eventsJson" rows="10" placeholder='[{"eventType": "...", "label": "...", "payload": {...}, "position": 0}]' required></textarea>
                </div>
                <button type="submit" class="ui blue button" onclick="return parseAndSubmitEvents()">
                  <i class="upload icon"></i>Importuj
                </button>
                <button type="button" class="ui button" onclick="toggleImportForm()">Anuluj</button>
              </form>
            </div>

            <div class="ui divided items" style="margin-top: 1em">
              <% events.forEach(function(event, idx) { %>
              <div class="item <% if (concert.activeEventId?.equals(event._id)) { %> selected <% } %>">
                <div class="content" style="width: 100%">
                  <div class="<% if (!concert.activeEventId?.equals(event._id)) { %> weight-normal <% } %> header">
                    <%= event.eventType %> (<%= event.label %>) <% if (concert.activeEventId?.equals(event._id)) { %>
                    <span class="ui green horizontal label" style="margin-left: 8px">AKTYWNY</span>
                    <% } %>
                    <button class="ui mini basic button" style="margin-left: 8px" onclick="togglePayload('<%= event._id %>')">
                      <i class="eye icon"></i> Pokaż payload
                    </button>
                  </div>
                  <div id="payload-<%= event._id %>" class="description" style="overflow: auto; display: none">
                    <pre style="margin: 0.5em 0 0.5em 0.5em; background: #f8f8f8; padding: 0.5em; border-radius: 4px; display: inline-block; font-size: small">
<%= JSON.stringify(event.payload, undefined, 2) %></pre
                    >
                  </div>
                  <div class="extra">
                    <div class="ui right floated">
                      <div class="ui icon buttons basic mini">
                        <form id="move-event-<%= event._id %>" method="POST" action="<%= url.admin %>/events/move/<%= event._id %>" style="display: inline"></form>

                        <button
                          type="submit"
                          name="direction"
                          value="up"
                          class="ui button"
                          title="Przesuń w górę"
                          form="move-event-<%= event._id %>"
                          <% if (event.position === 0) { %> disabled="disabled" <% } %>
                        >
                          <i class="arrow up icon"></i>
                        </button>

                        <button
                          type="submit"
                          name="direction"
                          value="down"
                          class="ui button"
                          title="Przesuń w dół"
                          form="move-event-<%= event._id %>"
                          <% if (event.position === events.length - 1) { %> disabled="disabled" <% } %>
                        >
                          <i class="arrow down icon"></i>
                        </button>

                        <a href="<%= url.admin %>/events/edit/<%= event._id %>" class="ui button" title="Edytuj komunikat"><i class="edit icon"></i> </a>

                        <form id="delete-event-<%= event._id %>" method="POST" action="<%= url.admin %>/events/delete/<%= event._id %>" style="display: inline"></form>
                        <button type="submit" class="ui red basic button" title="Usuń komunikat" form="delete-event-<%= event._id %>">
                          <i class="trash icon"></i>
                        </button>
                      </div>
                    </div>
                    <form method="POST" action="<%= url.admin %>/events/activate/<%= event._id %>" style="display: inline">
                      <input type="hidden" name="event_id" value="<%= event._id %>" />
                      <button type="submit" class="ui small button <%= concert.activeEventId?.equals(event._id) ? 'disabled' : '' %>" title="Ustaw jako aktywny">
                        <i class="play icon"></i> Ustaw jako aktywny
                      </button>
                    </form>
                     <form method="POST" action="<%= url.admin %>/events/activate/<%= event._id %>" style="display: inline">
                      <input type="hidden" name="event_id" value="<%= event._id %>" />
                      <button type="submit" class="ui small button <%= concert.activeEventId?.equals(event._id) ? '' : 'disabled' %>" title="Powtórz wysłanie">
                        <i class="play icon"></i> Powtórz wysłanie
                      </button>
                    </form>
                  </div>
                </div>
              </div>
              <% }) %>
            </div>
            <a href="<%= url.admin %>/" class="ui button"><i class="arrow left icon"></i>Powrót</a>
          </div>
        </div>
        <!-- Image management section -->
        <div class="column">
          <div class="ui segment">
            <h3 class="ui header">Zarządzanie obrazami</h3>
            
            <!-- Simple Image Upload -->
            <div class="ui segment">
              <h4 class="ui header">
                <i class="upload icon"></i>
                <div class="content">
                  Przesyłanie obrazów
                  <div class="sub header">Prześlij obraz i otrzymaj UUID do użycia w treści JSON</div>
                </div>
              </h4>
              
              <form action="/api/images/upload" method="POST" enctype="multipart/form-data" class="ui form" id="image-upload-form">
                <div class="field">
                  <div class="ui action input">
                    <input type="file" name="image" accept="image/*" required style="display: none;" id="image-file-input">
                    <input type="text" placeholder="Wybierz plik obrazu..." readonly id="image-filename-display">
                    <button type="button" class="ui icon button" onclick="document.getElementById('image-file-input').click();">
                      <i class="folder open outline icon"></i>
                    </button>
                    <button type="submit" class="ui primary button">Upload</button>
                  </div>
                </div>
              </form>
              
              <div id="upload-result" style="margin-top: 10px;"></div>
            </div>

            <!-- Usage instructions -->
            <div class="ui info message">
              <div class="header">Instrukcje użycia</div>
              <p>Po przesłaniu obrazu otrzymasz UUID. Użyj go w treści JSON:</p>
              <div class="ui code">&lt;image uuid="WKLEJ-TUTAJ-UUID"/&gt;</div>
              <p><strong>Kontrola rozmiaru:</strong></p>
              <div class="ui code">&lt;image uuid="UUID" width="20%"/&gt;</div>
              <div class="ui code">&lt;image uuid="UUID" width="50"/&gt;</div>
              <p>Tag zostanie automatycznie przekonwertowany na właściwy link do obrazu z odpowiednim rozmiarem.</p>
            </div>
            
            <!-- Images list -->
            <div class="ui segment">
              <h4 class="ui header">Wszystkie przesłane obrazy</h4>
              <div id="images-list-content">Ładowanie listy obrazów...</div>
            </div>
          </div>
        </div>
        
        <!-- Devices section -->
        <div class="column">
          <div class="ui segment">
            <h3 class="ui header">Urządzenia koncertu</h3>
            <div id="devices-table-container">
              <p>Ładowanie listy urządzeń...</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      // Toggle payload visibility
      function togglePayload(eventId) {
        const payloadDiv = document.getElementById('payload-' + eventId);
        const button = event.target.closest('button');
        const icon = button.querySelector('i');
        
        if (payloadDiv.style.display === 'none') {
          payloadDiv.style.display = 'block';
          button.innerHTML = '<i class="eye slash icon"></i> Ukryj payload';
        } else {
          payloadDiv.style.display = 'none';
          button.innerHTML = '<i class="eye icon"></i> Pokaż payload';
        }
      }

      // Toggle import form visibility
      function toggleImportForm() {
        const form = document.getElementById('import-events-form');
        if (form.style.display === 'none') {
          form.style.display = 'block';
        } else {
          form.style.display = 'none';
        }
      }

      // Parse JSON and submit
      function parseAndSubmitEvents() {
        const textarea = document.getElementById('eventsJson');
        try {
          const events = JSON.parse(textarea.value);
          if (!Array.isArray(events)) {
            alert('JSON musi być tablicą wydarzeń');
            return false;
          }
          
          // Create a hidden input field with the parsed events
          const form = textarea.closest('form');
          const hiddenInput = document.createElement('input');
          hiddenInput.type = 'hidden';
          hiddenInput.name = 'events';
          hiddenInput.value = JSON.stringify(events);
          form.appendChild(hiddenInput);
          
          return true;
        } catch (e) {
          alert('Nieprawidłowy JSON: ' + e.message);
          return false;
        }
      }

      // Devices AJAX logic (unchanged)
      const concertId = "<%= concert._id %>";
      function renderDevicesTable(devices) {
        const activeCount = devices.filter((d) => d.isActive).length;
        let html = `<p>Liczba zarejestrowanych: ${devices.length}</p>`;
        html += `<p>✅ Liczba aktywnych: ${activeCount}</p>`;
        html += `<table class="ui celled striped table">
            <thead><tr>
            <th>ID</th>
            <th>Typ</th>
            <th>Aktywny?</th>
            <th>Utworzony</th>
            </tr></thead><tbody>`;
        html += devices
          .map((user) => {
            return `<tr>
            <td>${user._id}</td>
            <td>${user.deviceType}</td>
            <td><span class='ui ${user.isActive ? "green" : "grey"} label'>${user.isActive ? "TAK" : "NIE"}</span></td>
            <td>${new Date(user.createdAt).toLocaleString()}</td>
            </tr>`;
          })
          .join("");
        html += `</tbody></table>`;
        document.getElementById("devices-table-container").innerHTML = html;
      }

      // Image management functions
      
      // File input handling
      document.getElementById('image-file-input').addEventListener('change', function(e) {
        const filename = e.target.files[0]?.name || '';
        document.getElementById('image-filename-display').value = filename;
      });
      
      // Upload form handling
      document.getElementById('image-upload-form').addEventListener('submit', function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        
        fetch('/api/images/upload', {
          method: 'POST',
          body: formData
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            loadImagesList(); // Refresh the images list
            document.getElementById('image-file-input').value = '';
            document.getElementById('image-filename-display').value = '';
            
            const resultDiv = document.getElementById('upload-result');
            resultDiv.innerHTML = `<div class="ui success message">
              <div class="header">Obraz przesłany pomyślnie!</div>
              <p><strong>UUID:</strong> <code>${data.image.uuid}</code></p>
              <p>Użyj tego UUID w treści JSON: <code>&lt;image uuid="${data.image.uuid}"/&gt;</code></p>
            </div>`;
          } else {
            const resultDiv = document.getElementById('upload-result');
            resultDiv.innerHTML = `<div class="ui error message">Błąd: ${data.error || 'Nieznany błąd'}</div>`;
          }
        })
        .catch(err => {
          console.error('Upload error:', err);
          const resultDiv = document.getElementById('upload-result');
          resultDiv.innerHTML = '<div class="ui error message">Błąd podczas przesyłania obrazu</div>';
        });
      });
      
      function loadImagesList() {
        fetch('/api/images/list')
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              const imagesListContent = document.getElementById('images-list-content');
              if (data.images.length === 0) {
                imagesListContent.innerHTML = '<p>Brak przesłanych obrazów.</p>';
              } else {
                let html = '<div class="ui small cards">';
                data.images.forEach(img => {
                  html += `<div class="card">
                    <div class="image">
                      <img src="/api/images/${img.uuid}" style="height: 100px; object-fit: cover;">
                    </div>
                    <div class="content">
                      <div class="header" style="font-size: 0.8em;">${img.originalName}</div>
                      <div class="meta">UUID: ${img.uuid}</div>
                      <div class="description" style="font-size: 0.8em;">
                        <code>&lt;image uuid="${img.uuid}"/&gt;</code>
                      </div>
                    </div>
                  </div>`;
                });
                html += '</div>';
                imagesListContent.innerHTML = html;
              }
            }
          })
          .catch(err => {
            console.error('Image list error:', err);
            document.getElementById('images-list-content').innerHTML = 'Błąd podczas ładowania listy obrazów.';
          });
      }
      
      // Initialize image management on page load
      loadImagesList();

      function fetchDevices() {
        fetch(`/api/user/concert/${concertId}`)
          .then((res) => res.json())
          .then((data) => {
            if (Array.isArray(data.data)) renderDevicesTable(data.data);
          });
      }
      setInterval(fetchDevices, 3000);
      fetchDevices();
      // Enable Semantic UI dropdowns
      document.addEventListener("DOMContentLoaded", function () {
        $(".ui.dropdown").dropdown();
      });
    </script>
  </body>
</html>
